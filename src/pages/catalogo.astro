---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ProductCatalog from "../components/ProductCatalog";
import { products } from "../data/products";
import { site } from "../data/site";

// Structured data — um Product por item do catálogo
const productLd = products.map((p) => ({
  "@context": "https://schema.org",
  "@type": "Product",
  name: p.name,
  category: p.category,
  description: p.description,
  image: new URL(p.image, site.url).href,
  brand: { "@type": "Brand", name: p.brand },
  url: `${site.url}/catalogo#${p.id}`,
}));
---

<Layout
  title="Catálogo"
  description="Conheça o catálogo da Laticínios Conquista: leite pasteurizado, bebida láctea fermentada, iogurte natural e manteiga ConLeite."
  jsonLd={productLd}
>
  <Header />

  <main class="pt-[68px]">
    <!-- Page header -->
    <section class="bg-white pt-16 pb-12 border-b border-line">
      <div class="max-w-6xl mx-auto px-5 sm:px-6 lg:px-8">
        <span class="eyebrow">Catálogo</span>
        <h1 class="font-display text-4xl md:text-6xl font-extrabold text-ink mt-5 leading-[1.0] max-w-3xl">
          Tudo o que sai da nossa fábrica
        </h1>
        <p class="text-lg text-muted leading-relaxed mt-5 max-w-2xl">
          Leite, bebida láctea, iogurte e manteiga das marcas Conquista e ConLeite.
          Clique em qualquer produto para ver descrição, sugestões de uso e a tabela
          nutricional.
        </p>
      </div>
    </section>

    <!-- Catalog grid + modais -->
    <section class="bg-milk py-14 min-h-[60vh]">
      <div class="max-w-6xl mx-auto px-5 sm:px-6 lg:px-8">
        <ProductCatalog client:load />
      </div>
    </section>
  </main>

  <Footer />
</Layout>
