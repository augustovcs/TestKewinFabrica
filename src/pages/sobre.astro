---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { whatsappLink } from "../data/site";

const wa = whatsappLink();

const story = [
  { title: "A origem", body: "A Laticínios Conquista nasceu em Vitória da Conquista com um propósito simples: levar leite de qualidade da nossa região para a mesa das famílias baianas." },
  { title: "O crescimento", body: "Com o tempo, a linha cresceu — do leite pasteurizado às bebidas lácteas fermentadas, ao iogurte natural e à manteiga ConLeite, sempre com o mesmo cuidado." },
  { title: "Hoje", body: "Um portfólio que acompanha o dia a dia da família, distribuído na região e reconhecido pelo sabor que se repete em cada embalagem." },
];

const principles = [
  { title: "Cuidado", body: "Tratar o alimento da família como se fosse o nosso. Esse é o ponto de partida de toda decisão." },
  { title: "Origem", body: "Valorizar o leite e o produtor da região. Quando a região prospera, o que chega à mesa é melhor." },
  { title: "Constância", body: "Qualidade não é evento, é hábito. O mesmo padrão em cada lote, em cada produto." },
];

const pillars = [
  { title: "Inspeção Federal", body: "Produção fiscalizada e Indústria Brasileira, conforme as embalagens." },
  { title: "Duas marcas, uma fábrica", body: "Conquista e ConLeite saem da mesma casa, com o mesmo compromisso." },
  { title: "Raiz regional", body: "Feito em Vitória da Conquista, para a Bahia e o Nordeste." },
];
---

<Layout
  title="A Empresa"
  description="Conheça a Laticínios Conquista: leite, bebida láctea, iogurte e manteiga feitos com cuidado em Vitória da Conquista, BA."
>
  <Header />

  <main class="pt-[68px]">
    <!-- Intro -->
    <section class="bg-white py-16 md:py-24">
      <div class="max-w-6xl mx-auto px-5 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-14 items-center">
          <div class="reveal reveal-left">
            <span class="eyebrow">Quem somos</span>
            <h1 class="font-display text-4xl md:text-[3.4rem] font-extrabold text-ink mt-5 leading-[1.02]">
              Laticínios com<br />sotaque do <span class="text-brand-green">campo</span>.
            </h1>
            <p class="text-lg text-muted leading-relaxed mt-6 max-w-xl">
              A Laticínios Conquista faz uma coisa só — e faz bem: levar leite e
              derivados de qualidade da região de Vitória da Conquista para a mesa
              das famílias. Sem atalhos, com o jeito de quem conhece o campo.
            </p>
            <div class="flex flex-wrap gap-3 mt-8">
              <a href="/catalogo" class="btn-primary">Ver catálogo</a>
              <a href={wa} target="_blank" rel="noopener" class="btn-ghost">Falar no WhatsApp</a>
            </div>
          </div>
          <div class="relative reveal reveal-right reveal-delay-1">
            <div class="aspect-[4/3] rounded-[22px] overflow-hidden shadow-2xl shadow-brand-green/15">
              <img src="/banners/banner-03.webp" alt="Família no café da manhã com produtos Laticínios Conquista" class="w-full h-full object-cover" loading="eager" width="1920" height="672" />
            </div>
            <div class="float-c absolute -bottom-6 -left-4 sm:-left-6 bg-white border border-line rounded-[14px] shadow-xl p-6 hidden sm:block">
              <div class="font-display text-xl font-extrabold text-brand-green leading-none">Vitória da Conquista</div>
              <div class="text-muted text-sm mt-1.5">Bahia · Brasil</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- História -->
    <section id="historia" class="bg-milk py-20 lg:py-24">
      <div class="max-w-6xl mx-auto px-5 sm:px-6 lg:px-8">
        <div class="max-w-2xl mb-12 reveal">
          <span class="eyebrow">Nossa história</span>
          <h2 class="font-display text-3xl md:text-[2.7rem] font-extrabold text-ink mt-4 leading-[1.05]">Do leite da região para a sua mesa</h2>
        </div>
        <div class="grid md:grid-cols-3 gap-5">
          {story.map((s, i) => (
            <div class={`group bg-white border border-line rounded-[18px] p-8 hover:-translate-y-2 hover:shadow-xl hover:shadow-black/5 hover:border-brand-lime/50 transition-all duration-300 reveal reveal-delay-${i}`} style="transition-timing-function: var(--ease-spring);">
              <div class="font-display text-5xl font-extrabold text-brand-lime/40 transition-colors group-hover:text-brand-lime/70">{String(i + 1).padStart(2, "0")}</div>
              <h3 class="font-display text-xl font-extrabold text-ink mt-2">{s.title}</h3>
              <p class="text-muted leading-relaxed mt-2">{s.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Princípios -->
    <section class="bg-white py-20 lg:py-24">
      <div class="max-w-6xl mx-auto px-5 sm:px-6 lg:px-8">
        <div class="max-w-2xl mb-12 reveal">
          <span class="eyebrow">No que acreditamos</span>
          <h2 class="font-display text-3xl md:text-[2.7rem] font-extrabold text-ink mt-4 leading-[1.05]">Três coisas que não abrimos mão</h2>
        </div>
        <div class="grid md:grid-cols-3 gap-5">
          {principles.map((p, i) => (
            <div class={`card p-8 hover:border-brand-green/40 hover:-translate-y-1 transition-all duration-300 reveal reveal-delay-${i}`} style="transition-timing-function: var(--ease-spring);">
              <h3 class="font-display text-xl font-extrabold text-ink">{p.title}</h3>
              <p class="text-muted leading-relaxed mt-2">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Pilares — faixa verde -->
    <section class="relative bg-brand-green grain py-16 lg:py-20 overflow-hidden">
      <div class="absolute -top-24 left-1/4 w-96 h-96 rounded-full bg-brand-lime/15 blur-[110px] blob pointer-events-none"></div>
      <div class="absolute -bottom-20 right-1/5 w-80 h-80 rounded-full bg-brand-pink/12 blur-[110px] blob pointer-events-none"></div>
      <div class="relative z-10 max-w-6xl mx-auto px-5 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-3 gap-8 md:gap-10">
          {pillars.map((p, i) => (
            <div class={`group text-white reveal reveal-delay-${i}`}>
              <div class="w-12 h-12 rounded-[12px] bg-white/12 flex items-center justify-center text-brand-lime mb-5 transition-transform duration-300 group-hover:scale-110 group-hover:-rotate-6">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7" d="M9 12l2 2 4-4m6 2a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
              </div>
              <h3 class="font-display text-xl font-extrabold">{p.title}</h3>
              <p class="text-white/70 leading-relaxed mt-2">{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA final -->
    <section class="bg-white py-20 lg:py-24">
      <div class="max-w-6xl mx-auto px-5 sm:px-6 lg:px-8">
        <div class="relative bg-milk rounded-[22px] px-8 py-12 md:px-14 md:py-14 text-center overflow-hidden reveal reveal-scale">
          <div class="absolute -top-16 -right-10 w-64 h-64 rounded-full bg-brand-lime/15 blur-[80px] blob pointer-events-none"></div>
          <h2 class="relative font-display text-2xl md:text-4xl font-extrabold text-ink leading-tight max-w-2xl mx-auto">
            Quer levar a Conquista para o seu ponto de venda?
          </h2>
          <p class="text-muted text-lg mt-4 max-w-xl mx-auto">Fale com a gente sobre pedidos, parcerias e distribuição.</p>
          <a href={wa} target="_blank" rel="noopener" class="btn-primary mt-8">Falar no WhatsApp</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
