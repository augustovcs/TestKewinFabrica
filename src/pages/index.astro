---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Carousel from "../components/Carousel";
import ProductShowcase from "../components/ProductShowcase";
import Windmill from "../components/Windmill.astro";
import Wave from "../components/Wave.astro";
import SocialFeed from "../components/SocialFeed";
import { instagramPosts } from "../data/instagram";
import { whatsappLink } from "../data/site";
import { site, fullAddress } from "../data/site";

const wa = whatsappLink();

// Redes sociais (section acima do footer)
const socialLinks = [
  { label: "TikTok", href: site.social.tiktok, path: "M16.6 5.82A4.28 4.28 0 0 1 15.54 3h-3.09v12.4a2.59 2.59 0 1 1-2.59-2.59c.27 0 .53.04.78.12V9.66a5.7 5.7 0 0 0-.78-.06 5.69 5.69 0 1 0 5.69 5.69V9.01a7.35 7.35 0 0 0 4.3 1.38V7.3a4.29 4.29 0 0 1-3.25-1.48Z" },
  { label: "Instagram", href: site.social.instagram, path: "M12 2.16c3.2 0 3.58.01 4.85.07 3.25.15 4.77 1.69 4.92 4.92.06 1.27.07 1.64.07 4.85s-.01 3.58-.07 4.85c-.15 3.23-1.66 4.77-4.92 4.92-1.27.06-1.64.07-4.85.07s-3.58-.01-4.85-.07c-3.26-.15-4.77-1.7-4.92-4.92C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85c.15-3.23 1.66-4.77 4.92-4.92C8.42 2.17 8.8 2.16 12 2.16Zm0 3.68a6.16 6.16 0 1 0 0 12.32 6.16 6.16 0 0 0 0-12.32ZM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8Zm6.41-11.85a1.44 1.44 0 1 0 0 2.88 1.44 1.44 0 0 0 0-2.88Z" },
  { label: "YouTube", href: site.social.youtube, path: "M23.5 6.2a3 3 0 0 0-2.11-2.13C19.5 3.55 12 3.55 12 3.55s-7.5 0-9.39.52A3 3 0 0 0 .5 6.2 31.3 31.3 0 0 0 0 12a31.3 31.3 0 0 0 .5 5.8 3 3 0 0 0 2.11 2.13c1.89.52 9.39.52 9.39.52s7.5 0 9.39-.52a3 3 0 0 0 2.11-2.13A31.3 31.3 0 0 0 24 12a31.3 31.3 0 0 0-.5-5.8ZM9.6 15.6V8.4l6.2 3.6Z" },
  { label: "Facebook", href: site.social.facebook, path: "M24 12.07C24 5.44 18.63.07 12 .07S0 5.44 0 12.07c0 5.99 4.39 10.95 10.13 11.85v-8.38H7.08v-3.47h3.05V9.43c0-3.01 1.79-4.67 4.53-4.67 1.31 0 2.69.24 2.69.24v2.95h-1.51c-1.49 0-1.96.93-1.96 1.87v2.25h3.33l-.53 3.47h-2.8v8.38C19.61 23.02 24 18.06 24 12.07Z" },
];

// Mundo de categorias color-coded
const lineCards = [
  { cat: "Leites", desc: "Pasteurizado integral e desnatado", tile: "from-brand-green-tint to-white", ring: "group-hover:ring-brand-green/40", icon: "text-brand-green", chip: "text-brand-green", iconPath: "M9 3h6l-1 4v0a3 3 0 003 3v8a3 3 0 01-3 3H10a3 3 0 01-3-3v-8a3 3 0 003-3v0L9 3z" },
  { cat: "Bebida Láctea", desc: "Morango, coco e ameixa", tile: "from-brand-pink-tint to-white", ring: "group-hover:ring-brand-pink/40", icon: "text-brand-pink", chip: "text-brand-pink-dark", iconPath: "M7 4h10l-1 16a2 2 0 01-2 2H10a2 2 0 01-2-2L7 4zM6 4h12" },
  { cat: "Iogurtes", desc: "Natural desnatado ConLeite", tile: "from-brand-lime-tint to-white", ring: "group-hover:ring-brand-lime/50", icon: "text-brand-lime-deep", chip: "text-brand-lime-deep", iconPath: "M6 8h12l-.7 11a2 2 0 01-2 1.9H8.7a2 2 0 01-2-1.9L6 8zM5 8l1-3h12l1 3" },
  { cat: "Derivados", desc: "Manteiga de primeira", tile: "from-line-manteiga/20 to-white", ring: "group-hover:ring-line-manteiga/60", icon: "text-[#a67c0d]", chip: "text-[#8a6a10]", iconPath: "M4 9h16v9a2 2 0 01-2 2H6a2 2 0 01-2-2V9zM3 9l2-4h14l2 4" },
];

const values = [
  { title: "Origem regional", body: "Leite de produtores da nossa região, processado pertinho de quem consome. Quando a região prospera, o que chega à mesa é melhor.", icon: "M3.06 11H5a2 2 0 0 1 2 2v1a2 2 0 0 0 2 2 2 2 0 0 1 2 2v2.95M8 3.94V5.5A2.5 2.5 0 0 0 10.5 8h.5a2 2 0 0 1 2 2 2 2 0 1 0 4 0 2 2 0 0 1 2-2h1.06M15 20.49V18a2 2 0 0 1 2-2h3.06M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" },
  { title: "Inspeção Federal", body: "Produção fiscalizada e controle de qualidade em todas as etapas. Cada lote é conferido antes de seguir para o ponto de venda.", icon: "M9 12l2 2 4-4m6 2a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" },
  { title: "Sabor que se repete", body: "O mesmo padrão em cada embalagem. Aquele gosto de leite de verdade que a família reconhece e confia.", icon: "M4.318 6.318a4.5 4.5 0 0 0 0 6.364L12 20.364l7.682-7.682a4.5 4.5 0 0 0-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 0 0-6.364 0Z" },
];

// Receitas & usos (estilo "prepare agora" da Batavo)
const recipes = [
  { title: "Vitamina de morango", body: "Bebida láctea de morango + banana + gelo. O lanche que a criançada ama.", image: "/produtos/IMG_7281.webp", id: "bebida-morango" },
  { title: "Molho de iogurte", body: "Iogurte natural, limão e ervas. Cremoso para saladas e petiscos.", image: "/produtos/IMG_7291.webp", id: "iogurte-natural" },
  { title: "Pão na chapa", body: "Manteiga ConLeite derretendo no pão quentinho. Café da manhã perfeito.", image: "/produtos/manteiga.webp", id: "manteiga" },
];

const contactItems = [
  { label: "Endereço", value: `${fullAddress} · CEP ${site.address.zip}`, href: site.mapsEmbed.replace("&output=embed", ""), icon: "M17.657 16.657L13.414 20.9a2 2 0 0 1-2.827 0l-4.244-4.243a8 8 0 1 1 11.314 0zM15 11a3 3 0 1 1-6 0 3 3 0 0 1 6 0z" },
  { label: "Telefone / WhatsApp", value: site.phones.map((p) => p.label).join("  ·  "), href: wa, icon: "M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" },
  { label: "E-mail", value: site.email, href: `mailto:${site.email}`, icon: "M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" },
];
---

<Layout title="Início">
  <Header />

  <main>
    <Carousel client:load />

    <!-- Moinho girando (scroll-cue estilo Batavo) — bem embaixo, quase no fim do bloco branco -->
    <div class="bg-white flex justify-center pt-16 sm:pt-24 pb-2">
      <Windmill />
    </div>

    

    <!-- Showcase de produtos — layout "criações da holandesa" full-bleed (título esquerda, carrossel direita) -->
    <section class="bg-milk py-20 lg:py-28 overflow-hidden">
      <div class="grid lg:grid-cols-[38%_1fr] gap-10 lg:gap-6 items-center">
        <div class="pl-5 sm:pl-8 lg:pl-[max(2rem,calc((100vw-1152px)/2))] pr-5 reveal reveal-left">
          <h2 class="font-display text-5xl md:text-7xl leading-[0.9] tracking-tight">
            <span class="block font-light text-muted">Os queridinhos</span>
            <span class="block font-extrabold text-brand-pink">da família</span>
          </h2>
          <a href="/catalogo" class="inline-flex items-center gap-2 font-bold text-brand-green hover:gap-3 transition-all mt-8 text-lg">
            Ver catálogo completo
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
        </div>
        <div class="min-w-0 reveal reveal-delay-1">
          <ProductShowcase client:visible />
        </div>
      </div>
    </section>

    <!-- Por que Conquista (valores) -->
    <section class="bg-white py-20 lg:py-24">
      <div class="max-w-6xl mx-auto px-5 sm:px-6 lg:px-8">
        <div class="max-w-2xl mb-12 reveal">
          <span class="eyebrow">Por que Conquista</span>
          <h2 class="font-display text-3xl md:text-[2.7rem] font-extrabold text-ink mt-4 leading-[1.05]">
            Leite de verdade começa antes da prateleira.
          </h2>
        </div>
        <div class="grid md:grid-cols-3 gap-5">
          {values.map((v, i) => (
            <div class={`group card p-8 hover:border-brand-green/40 hover:-translate-y-1 transition-all duration-300 reveal reveal-delay-${i}`} style="transition-timing-function: var(--ease-spring);">
              <div class="w-14 h-14 rounded-[14px] bg-brand-green-tint flex items-center justify-center text-brand-green mb-6 transition-transform duration-300 group-hover:scale-110 group-hover:-rotate-6">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d={v.icon} /></svg>
              </div>
              <h3 class="font-display text-xl font-extrabold text-ink mb-2">{v.title}</h3>
              <p class="text-muted leading-relaxed">{v.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- Fale Conosco -->
    <section id="contato" class="bg-milk py-20 lg:py-24 scroll-mt-20">
      <div class="max-w-6xl mx-auto px-5 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-10 lg:gap-14 items-stretch">
          <div class="reveal reveal-left">
            <span class="eyebrow">Fale conosco</span>
            <h2 class="font-display text-3xl md:text-[2.7rem] font-extrabold text-ink mt-4 leading-[1.05]">
              Vamos levar o melhor do campo até você?
            </h2>
            <p class="text-lg text-muted leading-relaxed mt-5 max-w-lg">
              Fale com a Laticínios Conquista sobre produtos, pedidos, parcerias e
              distribuição. Atendemos toda a região de Vitória da Conquista.
            </p>

            <ul class="mt-9 space-y-5">
              {contactItems.map((c) => (
                <li>
                  <a href={c.href} target="_blank" rel="noopener" class="group flex items-start gap-4">
                    <span class="flex-shrink-0 w-11 h-11 rounded-[12px] bg-white border border-line text-brand-green flex items-center justify-center group-hover:bg-brand-green group-hover:text-white group-hover:-rotate-6 transition-all">
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7" d={c.icon} /></svg>
                    </span>
                    <span>
                      <span class="block text-xs font-bold uppercase tracking-wide text-muted">{c.label}</span>
                      <span class="block text-ink font-semibold leading-snug mt-0.5 group-hover:text-brand-green transition-colors">{c.value}</span>
                    </span>
                  </a>
                </li>
              ))}
            </ul>

            <a href={wa} target="_blank" rel="noopener" class="btn-primary mt-9">
              <svg fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5"><path d="M17.47 14.38c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.96-.94 1.16-.17.2-.35.22-.64.08-.3-.15-1.26-.47-2.39-1.48-.88-.79-1.48-1.76-1.65-2.06-.17-.3-.02-.46.13-.6.13-.14.3-.35.45-.52.15-.18.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.61-.92-2.21-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.48s1.07 2.88 1.21 3.07c.15.2 2.1 3.2 5.08 4.49.71.3 1.26.49 1.69.62.71.23 1.36.2 1.87.12.57-.08 1.76-.72 2-1.41.25-.7.25-1.29.18-1.41-.08-.13-.27-.2-.57-.35M12.05 21.79h-.01a9.87 9.87 0 0 1-5.03-1.38l-.36-.21-3.74.98 1-3.65-.24-.37a9.86 9.86 0 0 1-1.51-5.26c0-5.45 4.44-9.88 9.89-9.88 2.64 0 5.12 1.03 6.98 2.9a9.83 9.83 0 0 1 2.9 6.99c0 5.45-4.44 9.88-9.88 9.88" /></svg>
              Chamar no WhatsApp
            </a>
          </div>

          <div class="reveal reveal-right min-h-[320px] lg:min-h-0">
            <div class="h-full rounded-[18px] overflow-hidden border border-line shadow-sm">
              <iframe
                title={`Localização — ${site.brand}`}
                src={site.mapsEmbed}
                class="w-full h-full min-h-[320px]"
                style="border:0"
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                allowfullscreen
              ></iframe>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Redes sociais (acima do footer) — bloco branco alto (dá respiro p/ a onda grande) -->
    <section class="bg-white pt-24 lg:pt-32 pb-56 lg:pb-72 overflow-hidden">
      <div class="max-w-6xl mx-auto px-5 sm:px-6 lg:px-8">
        <SocialFeed
          client:visible
          feedId={site.social.beholdFeedId}
          handle={site.social.handle}
          instagram={site.social.instagram}
          posts={instagramPosts}
          socials={socialLinks}
        />
      </div>
    </section>

  </main>

  <Footer />
</Layout>

<script>
  // Parallax leve na faixa editorial
  const el = document.querySelector<HTMLImageElement>("[data-parallax]");
  if (el && !matchMedia("(prefers-reduced-motion: reduce)").matches) {
    const onScroll = () => {
      const rect = el.getBoundingClientRect();
      if (rect.bottom < 0 || rect.top > window.innerHeight) return;
      const p = (window.innerHeight - rect.top) / (window.innerHeight + rect.height);
      el.style.transform = `translateY(${(p - 0.5) * -12}%)`;
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();
  }
</script>
