---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero';
import About from '../components/About';
import ProductCarousel from '../components/ProductCarousel';
import Stats from '../components/Stats.astro';
import WaveDivider from '../components/WaveDivider.astro';
---

<Layout title="Início">
	<Header />
	
	<main class="pt-20">
		<div class="relative">
			<Hero client:load />
			<WaveDivider position="bottom" fillColor="#F7F7F7" className="z-20" />
		</div>
		
		<About client:visible />
		
		<div class="relative">
			<WaveDivider position="top" fillColor="#F7F7F7" className="rotate-180 -scale-x-100 z-10" />
			<ProductCarousel client:visible />
		</div>
		
		<Stats />
		
		<section id="certificacoes" class="py-24 bg-white relative">
			<WaveDivider position="top" fillColor="#1E4E8C" className="rotate-180 -scale-x-100 z-10 -mt-1" />
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-10">
				<div class="text-center mb-16">
					<h2 class="text-brand-orange font-bold tracking-wider uppercase text-sm mb-3">Nossas Certificações</h2>
					<h3 class="text-3xl md:text-4xl font-extrabold text-brand-dark">Garantia de Qualidade</h3>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					<div class="bg-gray-50 p-8 rounded-2xl border border-gray-100 text-center hover:shadow-xl transition-shadow duration-300">
						<div class="w-20 h-20 mx-auto bg-white rounded-full border-4 border-brand-blue flex items-center justify-center mb-6 text-brand-blue">
							<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
						</div>
						<h4 class="font-bold text-xl mb-3">Inspeção Federal (SIF)</h4>
						<p class="text-gray-600 text-sm">Garantimos a qualidade rigorosa exigida pelo Ministério da Agricultura em todas as etapas.</p>
					</div>
					<div class="bg-gray-50 p-8 rounded-2xl border border-gray-100 text-center hover:shadow-xl transition-shadow duration-300">
						<div class="w-20 h-20 mx-auto bg-white rounded-full border-4 border-brand-orange flex items-center justify-center mb-6 text-brand-orange">
							<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
						</div>
						<h4 class="font-bold text-xl mb-3">Laboratório Próprio</h4>
						<p class="text-gray-600 text-sm">Testes diários rigorosos para assegurar o mais alto padrão de pureza do nosso leite.</p>
					</div>
					<div class="bg-gray-50 p-8 rounded-2xl border border-gray-100 text-center hover:shadow-xl transition-shadow duration-300">
						<div class="w-20 h-20 mx-auto bg-white rounded-full border-4 border-conquista-green flex items-center justify-center mb-6 text-conquista-green">
							<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
						</div>
						<h4 class="font-bold text-xl mb-3">Sustentabilidade</h4>
						<p class="text-gray-600 text-sm">Compromisso com o meio ambiente no tratamento de efluentes e eficiência energética.</p>
					</div>
				</div>
			</div>
		</section>
		
	</main>
	
	<Footer />
</Layout>

<style>
	/* Any additional minor tweaks can go here */
</style>
