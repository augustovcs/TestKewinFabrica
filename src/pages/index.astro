---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Hero from "../components/Hero";
import { products } from "../data/products";

const featured = products.slice(0, 4);

const values = [
  {
    title: "Produtores da região",
    body: "Parceria direta com fazendas vizinhas. O leite sai do pasto e chega à fábrica em poucas horas.",
    icon: "M3.06 11H5a2 2 0 0 1 2 2v1a2 2 0 0 0 2 2 2 2 0 0 1 2 2v2.95M8 3.94V5.5A2.5 2.5 0 0 0 10.5 8h.5a2 2 0 0 1 2 2 2 2 0 1 0 4 0 2 2 0 0 1 2-2h1.06M15 20.49V18a2 2 0 0 1 2-2h3.06M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z",
  },
  {
    title: "Inspeção e laboratório",
    body: "Selo SIF e laboratório próprio com testes diários. Cada lote é conferido antes de seguir viagem.",
    icon: "M9 12l2 2 4-4m6 2a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z",
  },
  {
    title: "Sabor que se repete",
    body: "Padrão constante há mais de 25 anos. O leite que você lembra da infância, do mesmo jeito.",
    icon: "M4.318 6.318a4.5 4.5 0 0 0 0 6.364L12 20.364l7.682-7.682a4.5 4.5 0 0 0-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 0 0-6.364 0Z",
  },
];

const accentText = {
  blue: "text-brand-blue",
  orange: "text-brand-orange-dark",
  green: "text-conquista-green",
  pink: "text-conquista-pink",
} as const;
---

<Layout title="Início">
  <Header transparent />

  <main>
    <Hero client:load />

    <!-- Values -->
    <section class="bg-white py-24">
      <div class="max-w-6xl mx-auto px-5 sm:px-6 lg:px-8">
        <div class="max-w-2xl mb-14">
          <span class="text-sm font-semibold text-brand-blue uppercase tracking-wide">Por que Conleite</span>
          <h2 class="font-display text-4xl md:text-5xl font-bold text-ink mt-3 leading-tight">
            Leite de verdade começa antes da prateleira.
          </h2>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          {values.map((v) => (
            <div class="rounded-2xl border border-line p-8 hover:border-brand-blue/30 hover:shadow-lg hover:shadow-brand-blue/5 transition-all duration-300">
              <div class="w-12 h-12 rounded-xl bg-brand-blue-tint flex items-center justify-center text-brand-blue mb-6">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={v.icon} /></svg>
              </div>
              <h3 class="font-display text-xl font-bold text-ink mb-2">{v.title}</h3>
              <p class="text-muted leading-relaxed">{v.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Featured products -->
    <section class="bg-milk py-24">
      <div class="max-w-6xl mx-auto px-5 sm:px-6 lg:px-8">
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-12">
          <div class="max-w-xl">
            <span class="text-sm font-semibold text-brand-orange-dark uppercase tracking-wide">Catálogo</span>
            <h2 class="font-display text-4xl md:text-5xl font-bold text-ink mt-3 leading-tight">
              Alguns dos nossos destaques
            </h2>
          </div>
          <a href="/catalogo" class="inline-flex items-center gap-2 font-semibold text-brand-blue hover:gap-3 transition-all">
            Ver catálogo completo
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
        </div>

        <div class="grid grid-cols-2 lg:grid-cols-4 gap-5">
          {featured.map((p) => (
            <a href={`/catalogo#${p.id}`} class="group bg-white rounded-2xl overflow-hidden border border-line hover:shadow-xl hover:shadow-black/5 transition-all duration-300 hover:-translate-y-1">
              <div class="aspect-[4/3] overflow-hidden">
                <img src={p.image} alt={p.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
              </div>
              <div class="p-5">
                <span class={`text-xs font-semibold uppercase tracking-wide ${accentText[p.accent]}`}>{p.brand}</span>
                <h3 class="font-display font-bold text-ink mt-1.5 leading-snug">{p.name}</h3>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Stats band (signature contrast) -->
    <section class="bg-night py-20">
      <div class="max-w-6xl mx-auto px-5 sm:px-6 lg:px-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
          {[
            { v: "25+", l: "anos de mercado" },
            { v: "50k", l: "litros por dia" },
            { v: "40+", l: "produtos no portfólio" },
            { v: "100k", l: "famílias atendidas" },
          ].map((s) => (
            <div>
              <div class="font-display text-4xl md:text-5xl font-bold text-white">{s.v}</div>
              <div class="text-white/55 text-sm mt-2">{s.l}</div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
