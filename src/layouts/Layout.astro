---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = 'Conleite - Desde 1999, levando o melhor do campo para a sua mesa com qualidade, confiança e o verdadeiro sabor do leite.' } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="theme-color" content="#1E8A4C" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title} | Conleite — Do Campo à Sua Mesa</title>
		
		<!-- Typography: Bricolage Grotesque (display) + Inter (body) -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400..800&family=Hanken+Grotesk:wght@400;500;600;700;800&display=swap" rel="stylesheet">

		<!-- Open Graph -->
		<meta property="og:title" content={`${title} | Conleite`} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
	</head>
	<body class="bg-white overflow-x-hidden">
		<slot />
	</body>
</html>
