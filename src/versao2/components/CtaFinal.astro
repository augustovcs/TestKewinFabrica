---
// CTA final — encerra com força e reaproveita o bloco "Fale conosco"
// (endereço, telefone, e-mail e mapa) que já existia na Home.
import { site, fullAddress, whatsappLink } from "../data/site";

const wa = whatsappLink();

const contactItems = [
  { label: "Endereço", value: `${fullAddress} · CEP ${site.address.zip}`, href: site.mapsEmbed.replace("&output=embed", ""), icon: "M17.657 16.657L13.414 20.9a2 2 0 0 1-2.827 0l-4.244-4.243a8 8 0 1 1 11.314 0zM15 11a3 3 0 1 1-6 0 3 3 0 0 1 6 0z" },
  { label: "Telefone / WhatsApp", value: site.phones.map((p) => p.label).join("  ·  "), href: wa, icon: "M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" },
  { label: "E-mail", value: site.email, href: `mailto:${site.email}`, icon: "M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" },
];
---

<section id="contato" class="bg-white py-20 lg:py-24 scroll-mt-20">
  <div class="max-w-6xl mx-auto px-5 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-10 lg:gap-14 items-stretch">
      <!-- Texto + CTA + contatos -->
      <div class="reveal reveal-left">
        <span class="eyebrow">Fale conosco</span>
        <h2 class="font-display text-3xl md:text-[2.9rem] font-extrabold text-ink mt-4 leading-[1.05]">
          Vamos crescer juntos?
        </h2>
        <p class="text-lg text-muted leading-relaxed mt-5 max-w-lg">
          Fale com a Laticínios Conquista sobre produtos, pedidos, parcerias e
          distribuição. Atendemos toda a região de Vitória da Conquista.
        </p>

        <a href={wa} target="_blank" rel="noopener" class="btn-primary mt-8">
          <svg fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5"><path d="M17.47 14.38c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.96-.94 1.16-.17.2-.35.22-.64.08-.3-.15-1.26-.47-2.39-1.48-.88-.79-1.48-1.76-1.65-2.06-.17-.3-.02-.46.13-.6.13-.14.3-.35.45-.52.15-.18.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.61-.92-2.21-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.48s1.07 2.88 1.21 3.07c.15.2 2.1 3.2 5.08 4.49.71.3 1.26.49 1.69.62.71.23 1.36.2 1.87.12.57-.08 1.76-.72 2-1.41.25-.7.25-1.29.18-1.41-.08-.13-.27-.2-.57-.35M12.05 21.79h-.01a9.87 9.87 0 0 1-5.03-1.38l-.36-.21-3.74.98 1-3.65-.24-.37a9.86 9.86 0 0 1-1.51-5.26c0-5.45 4.44-9.88 9.89-9.88 2.64 0 5.12 1.03 6.98 2.9a9.83 9.83 0 0 1 2.9 6.99c0 5.45-4.44 9.88-9.88 9.88" /></svg>
          Solicitar orçamento
        </a>

        <ul class="mt-10 space-y-5">
          {contactItems.map((c) => (
            <li>
              <a href={c.href} target="_blank" rel="noopener" class="group flex items-start gap-4">
                <span class="flex-shrink-0 w-11 h-11 rounded-[12px] bg-milk border border-line text-brand-green flex items-center justify-center group-hover:bg-brand-green group-hover:text-white group-hover:-rotate-6 transition-all">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7" d={c.icon} /></svg>
                </span>
                <span>
                  <span class="block text-xs font-bold uppercase tracking-wide text-muted">{c.label}</span>
                  <span class="block text-ink font-semibold leading-snug mt-0.5 group-hover:text-brand-green transition-colors">{c.value}</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Mapa -->
      <div class="reveal reveal-right min-h-[320px] lg:min-h-0">
        <div class="h-full rounded-[18px] overflow-hidden border border-line shadow-sm">
          <iframe
            title={`Localização — ${site.brand}`}
            src={site.mapsEmbed}
            class="w-full h-full min-h-[320px]"
            style="border:0"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    </div>
  </div>
</section>
