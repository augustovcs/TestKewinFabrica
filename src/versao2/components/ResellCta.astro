---
// Faixa compacta de CTA para revendedores — fica logo acima do Footer.
import { whatsappLink } from "../data/site";
const wa = whatsappLink();
---

<section class="bg-brand-green-ink">
  <div class="max-w-6xl mx-auto px-5 sm:px-6 lg:px-8 py-12 lg:py-14">
    <div class="reveal flex flex-col sm:flex-row items-center justify-between gap-6 text-center sm:text-left">
      <h2 class="font-display text-2xl sm:text-3xl font-extrabold text-white">
        Quer revender nossos produtos?
      </h2>
      <a
        href={wa}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2.5 bg-brand-lime text-brand-green-ink font-bold px-7 py-3.5 rounded-full hover:bg-white hover:-translate-y-1 hover:shadow-xl hover:shadow-black/20 transition-all duration-200 shrink-0"
        style="transition-timing-function: var(--ease-spring);"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.47 14.38c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.96-.94 1.16-.17.2-.35.22-.64.08-.3-.15-1.26-.47-2.39-1.48-.88-.79-1.48-1.76-1.65-2.06-.17-.3-.02-.46.13-.6.13-.14.3-.35.45-.52.15-.18.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.61-.92-2.21-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.48s1.07 2.88 1.21 3.07c.15.2 2.1 3.2 5.08 4.49.71.3 1.26.49 1.69.62.71.23 1.36.2 1.87.12.57-.08 1.76-.72 2-1.41.25-.7.25-1.29.18-1.41-.08-.13-.27-.2-.57-.35M12.05 21.79h-.01a9.87 9.87 0 0 1-5.03-1.38l-.36-.21-3.74.98 1-3.65-.24-.37a9.86 9.86 0 0 1-1.51-5.26c0-5.45 4.44-9.88 9.89-9.88 2.64 0 5.12 1.03 6.98 2.9a9.83 9.83 0 0 1 2.9 6.99c0 5.45-4.44 9.88-9.88 9.88" /></svg>
        Falar no WhatsApp
      </a>
    </div>
  </div>
</section>
