---
// Moinho line-art com pás girando (scroll-cue estilo Batavo). Verde da marca.
interface Props { class?: string }
const { class: cls = "" } = Astro.props;
---
<a href="#linhas" aria-label="Rolar para o conteúdo" class:list={["group inline-flex flex-col items-center", cls]}>
  <svg viewBox="0 0 100 120" class="w-14 h-[4.4rem] sm:w-16 sm:h-[5rem] text-brand-green" aria-hidden="true">
    <!-- torre -->
    <path fill="currentColor" d="M40 60 L60 60 L66 112 A2 2 0 0 1 64 114 L36 114 A2 2 0 0 1 34 112 Z" />
    <!-- porta -->
    <path fill="#fff" d="M46 90 Q50 84 54 90 L54 104 L46 104 Z" opacity="0.9" />
    <!-- teto -->
    <path fill="currentColor" d="M50 50 L63 64 L37 64 Z" />
    <!-- pás girando (bbox simétrico no hub 50,50) -->
    <g class="spin-blades" fill="#fff" stroke="currentColor" stroke-width="3" stroke-linejoin="round">
      <rect x="45" y="12" width="10" height="34" rx="1.5" />
      <rect x="54" y="45" width="34" height="10" rx="1.5" />
      <rect x="45" y="54" width="10" height="34" rx="1.5" />
      <rect x="12" y="45" width="34" height="10" rx="1.5" />
      <g stroke-width="2">
        <line x1="45" y1="29" x2="55" y2="29" />
        <line x1="71" y1="45" x2="71" y2="55" />
        <line x1="45" y1="71" x2="55" y2="71" />
        <line x1="29" y1="45" x2="29" y2="55" />
      </g>
      <circle cx="50" cy="50" r="5" fill="currentColor" stroke="none" />
    </g>
  </svg>
  <svg class="scroll-cue w-5 h-5 text-brand-green/70 mt-1 group-hover:text-brand-green transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.4" d="m6 9 6 6 6-6" />
  </svg>
</a>
