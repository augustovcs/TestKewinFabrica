---
import { site, whatsappLink } from "../data/site";
import { products } from "../data/products";
const year = new Date().getFullYear();
const wa = whatsappLink();

const socials = [
  { label: "Instagram", href: site.social.instagram, path: "M12 2.16c3.2 0 3.58.01 4.85.07 3.25.15 4.77 1.69 4.92 4.92.06 1.27.07 1.64.07 4.85s-.01 3.58-.07 4.85c-.15 3.23-1.66 4.77-4.92 4.92-1.27.06-1.64.07-4.85.07s-3.58-.01-4.85-.07c-3.26-.15-4.77-1.7-4.92-4.92C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85c.15-3.23 1.66-4.77 4.92-4.92C8.42 2.17 8.8 2.16 12 2.16Zm0 3.68a6.16 6.16 0 1 0 0 12.32 6.16 6.16 0 0 0 0-12.32ZM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8Zm6.41-11.85a1.44 1.44 0 1 0 0 2.88 1.44 1.44 0 0 0 0-2.88Z" },
  { label: "Facebook", href: site.social.facebook, path: "M24 12.07C24 5.44 18.63.07 12 .07S0 5.44 0 12.07c0 5.99 4.39 10.95 10.13 11.85v-8.38H7.08v-3.47h3.05V9.43c0-3.01 1.79-4.67 4.53-4.67 1.31 0 2.69.24 2.69.24v2.95h-1.51c-1.49 0-1.96.93-1.96 1.87v2.25h3.33l-.53 3.47h-2.8v8.38C19.61 23.02 24 18.06 24 12.07Z" },
  { label: "WhatsApp", href: wa, path: "M17.47 14.38c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.96-.94 1.16-.17.2-.35.22-.64.08-.3-.15-1.26-.47-2.39-1.48-.88-.79-1.48-1.76-1.65-2.06-.17-.3-.02-.46.13-.6.13-.14.3-.35.45-.52.15-.18.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.61-.92-2.21-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.48s1.07 2.88 1.21 3.07c.15.2 2.1 3.2 5.08 4.49.71.3 1.26.49 1.69.62.71.23 1.36.2 1.87.12.57-.08 1.76-.72 2-1.41.25-.7.25-1.29.18-1.41-.08-.13-.27-.2-.57-.35M12.05 21.79h-.01a9.87 9.87 0 0 1-5.03-1.38l-.36-.21-3.74.98 1-3.65-.24-.37a9.86 9.86 0 0 1-1.51-5.26c0-5.45 4.44-9.88 9.89-9.88 2.64 0 5.12 1.03 6.98 2.9a9.83 9.83 0 0 1 2.9 6.99c0 5.45-4.44 9.88-9.88 9.88" },
];

// Colunas de navegação (conteúdo real Conquista)
const categorias = ["Leites", "Bebida Láctea", "Iogurtes", "Derivados"];
const marcas = [site.brandShort, site.subBrand];
const tiposA = products.slice(0, 4);
const tiposB = products.slice(4);
const navegacao = [
  { label: "Início", href: "/versao2" },
  { label: "A Empresa", href: "/versao2/sobre" },
  { label: "Catálogo", href: "/versao2/catalogo" },
  { label: "Fale conosco", href: "/#contato" },
];
const institucional = [
  { label: "A Empresa", href: "/versao2/sobre" },
  { label: "Fale conosco", href: "/#contato" },
];

---

<footer id="contato-footer" class="relative bg-brand-green-ink text-white">
  <div class="relative z-10 max-w-6xl mx-auto px-5 sm:px-6 lg:px-8 pt-14 pb-24 lg:pt-20 lg:pb-32">
    <!-- Logo + contato rápido -->
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-10 pb-12 mb-12 border-b border-white/10 reveal">
      <div>
        <div class="inline-flex items-center rounded-[16px] px-5 py-4" style="background: rgba(255,255,255,.08); backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,.15);">
          <img src="/logo.webp" alt={site.brand} width="180" height="62" class="h-11 w-auto" />
        </div>
        <p class="text-white/55 text-sm mt-4 max-w-xs leading-relaxed">{site.tagline}.</p>
      </div>
      <div class="flex flex-col sm:flex-row sm:items-start gap-5 sm:gap-8 text-sm">
        <a href={wa} target="_blank" rel="noopener" class="group inline-flex items-center gap-2.5 bg-brand-green hover:bg-brand-lime hover:text-brand-green-ink text-white font-semibold px-5 py-3 rounded-full transition-all duration-200 hover:-translate-y-0.5" style="transition-timing-function: var(--ease-spring);">
          <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M17.47 14.38c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.96-.94 1.16-.17.2-.35.22-.64.08-.3-.15-1.26-.47-2.39-1.48-.88-.79-1.48-1.76-1.65-2.06-.17-.3-.02-.46.13-.6.13-.14.3-.35.45-.52.15-.18.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.61-.92-2.21-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.48s1.07 2.88 1.21 3.07c.15.2 2.1 3.2 5.08 4.49.71.3 1.26.49 1.69.62.71.23 1.36.2 1.87.12.57-.08 1.76-.72 2-1.41.25-.7.25-1.29.18-1.41-.08-.13-.27-.2-.57-.35M12.05 21.79h-.01a9.87 9.87 0 0 1-5.03-1.38l-.36-.21-3.74.98 1-3.65-.24-.37a9.86 9.86 0 0 1-1.51-5.26c0-5.45 4.44-9.88 9.89-9.88 2.64 0 5.12 1.03 6.98 2.9a9.83 9.83 0 0 1 2.9 6.99c0 5.45-4.44 9.88-9.88 9.88" /></svg>
          {site.phones.map((p) => p.label).join(" · ")}
        </a>
        <a href={`mailto:${site.email}`} class="group flex items-start gap-3 pt-2">
          <svg class="w-5 h-5 text-brand-lime shrink-0 mt-0.5 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
          <span class="text-white/70 group-hover:text-white transition-colors">{site.email}</span>
        </a>
        <a href={site.mapsEmbed.replace("&output=embed", "")} target="_blank" rel="noopener" class="group flex items-start gap-3 pt-2">
          <svg class="w-5 h-5 text-brand-lime shrink-0 mt-0.5 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7" d="M17.657 16.657L13.414 20.9a2 2 0 0 1-2.827 0l-4.244-4.243a8 8 0 1 1 11.314 0zM15 11a3 3 0 1 1-6 0 3 3 0 0 1 6 0z" /></svg>
          <span class="text-white/70 group-hover:text-white transition-colors leading-snug">{site.address.street} — {site.address.city}/{site.address.state}</span>
        </a>
      </div>
    </div>

    <!-- Colunas de navegação (6) -->
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-8 lg:gap-6 mb-14 reveal">
      <div>
        <h3 class="text-sm font-bold text-white/90 mb-5">Categorias</h3>
        <ul class="space-y-3 text-sm">
          {categorias.map((c) => (
            <li><a href="/versao2/catalogo" class="inline-block text-white/60 hover:text-brand-lime hover:translate-x-0.5 transition-all duration-200">{c}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-bold text-white/90 mb-5">Marcas</h3>
        <ul class="space-y-3 text-sm">
          {marcas.map((m) => (
            <li><a href="/versao2/catalogo" class="inline-block text-white/60 hover:text-brand-lime hover:translate-x-0.5 transition-all duration-200">{m}</a></li>
          ))}
        </ul>
      </div>

      <!-- Tipos de Produto — 2 sub-colunas -->
      <div>
        <h3 class="text-sm font-bold text-white/90 mb-5">Tipos de Produto</h3>
        <ul class="space-y-3 text-sm">
          {tiposA.map((p) => (
            <li><a href={`/catalogo#${p.id}`} class="inline-block text-white/60 hover:text-brand-lime hover:translate-x-0.5 transition-all duration-200">{p.name}</a></li>
          ))}
        </ul>
      </div>
      <div class="lg:pt-9">
        <ul class="space-y-3 text-sm">
          {tiposB.map((p) => (
            <li><a href={`/catalogo#${p.id}`} class="inline-block text-white/60 hover:text-brand-lime hover:translate-x-0.5 transition-all duration-200">{p.name}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-bold text-white/90 mb-5">Navegação</h3>
        <ul class="space-y-3 text-sm">
          {navegacao.map((n) => (
            <li><a href={n.href} class="inline-block text-white/60 hover:text-brand-lime hover:translate-x-0.5 transition-all duration-200">{n.label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-bold text-white/90 mb-5">Institucional</h3>
        <ul class="space-y-3 text-sm">
          {institucional.map((n) => (
            <li><a href={n.href} class="inline-block text-white/60 hover:text-brand-lime hover:translate-x-0.5 transition-all duration-200">{n.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Sociais bare bottom-left + copyright minimal (tudo à esquerda) -->
    <div class="border-t border-white/10 pt-7 flex flex-col gap-5 items-start">
      <div class="flex items-center gap-5">
        {socials.map((s) => (
          <a href={s.href} target="_blank" rel="noopener" aria-label={s.label} class="text-white/55 hover:text-brand-lime transition-colors">
            <svg fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5"><path d={s.path} /></svg>
          </a>
        ))}
      </div>
      <p class="text-sm text-white/45">© {year} {site.brand}. Todos os direitos reservados.</p>
    </div>
  </div>
</footer>
