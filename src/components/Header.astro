---
interface Props {
  /** quando true, o header começa transparente sobre o hero (apenas na home) */
  transparent?: boolean;
}
const { transparent = false } = Astro.props;
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);

const links = [
  { href: "/", label: "Início" },
  { href: "/sobre", label: "A Empresa" },
  { href: "/catalogo", label: "Catálogo" },
];
---

<header
  id="main-header"
  data-transparent={transparent ? "true" : "false"}
  class:list={[
    "fixed top-0 left-0 w-full z-50 transition-all duration-300",
    transparent ? "bg-transparent" : "bg-white/90 backdrop-blur-md border-b border-line",
  ]}
>
  <div class="max-w-6xl mx-auto px-5 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-[68px]">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 group" id="logo-link">
        <span
          id="logo-mark"
          class:list={[
            "w-9 h-9 rounded-xl flex items-center justify-center font-display font-bold text-lg transition-colors duration-300",
            transparent ? "bg-white/15 text-white ring-1 ring-white/25" : "bg-brand-blue text-white",
          ]}>C</span>
        <span
          id="logo-text"
          class:list={[
            "font-display font-bold text-xl tracking-tight transition-colors duration-300",
            transparent ? "text-white" : "text-ink",
          ]}>Conleite</span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-1" id="desktop-nav">
        {links.map((l) => (
          <a
            href={l.href}
            data-nav
            data-active={isActive(l.href) ? "true" : "false"}
            class:list={[
              "nav-link px-3.5 py-2 text-sm font-medium rounded-lg transition-colors duration-200",
              transparent ? "text-white/85 hover:text-white hover:bg-white/10" : "text-muted hover:text-ink hover:bg-milk",
              isActive(l.href) && (transparent ? "text-white" : "text-ink"),
            ]}
          >{l.label}</a>
        ))}
      </nav>

      <!-- CTA -->
      <div class="hidden md:flex items-center gap-3">
        <a
          href="/catalogo"
          id="cta-button"
          class="bg-brand-orange text-white px-5 py-2.5 rounded-full font-semibold text-sm hover:bg-brand-orange-dark transition-colors duration-200"
        >Ver produtos</a>
      </div>

      <!-- Mobile toggle -->
      <button
        type="button"
        id="mobile-menu-btn"
        aria-controls="mobile-menu"
        aria-expanded="false"
        aria-label="Abrir menu"
        class:list={[
          "md:hidden w-10 h-10 flex items-center justify-center rounded-lg transition-colors",
          transparent ? "text-white hover:bg-white/10" : "text-ink hover:bg-milk",
        ]}
      >
        <svg id="menu-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7h16M4 12h16M4 17h16" /></svg>
        <svg id="close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18 18 6M6 6l12 12" /></svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden hidden border-t border-line bg-white">
    <div class="px-5 py-4 space-y-1">
      {links.map((l) => (
        <a href={l.href} class="block px-4 py-3 rounded-xl text-base font-medium text-ink hover:bg-milk transition-colors">{l.label}</a>
      ))}
      <a href="/catalogo" class="block mt-2 text-center bg-brand-orange text-white px-5 py-3 rounded-full font-semibold">Ver produtos</a>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById("main-header");
  const startsTransparent = header?.dataset.transparent === "true";

  if (startsTransparent && header) {
    const logoMark = document.getElementById("logo-mark");
    const logoText = document.getElementById("logo-text");
    const navLinks = document.querySelectorAll<HTMLElement>("[data-nav]");
    const toggle = document.getElementById("mobile-menu-btn");
    let solid = false;

    const setSolid = (on: boolean) => {
      if (on === solid) return;
      solid = on;
      header.classList.toggle("bg-transparent", !on);
      header.classList.toggle("bg-white/90", on);
      header.classList.toggle("backdrop-blur-md", on);
      header.classList.toggle("border-b", on);
      header.classList.toggle("border-line", on);

      logoMark?.classList.toggle("bg-white/15", !on);
      logoMark?.classList.toggle("text-white", !on);
      logoMark?.classList.toggle("ring-1", !on);
      logoMark?.classList.toggle("ring-white/25", !on);
      logoMark?.classList.toggle("bg-brand-blue", on);

      logoText?.classList.toggle("text-white", !on);
      logoText?.classList.toggle("text-ink", on);

      toggle?.classList.toggle("text-white", !on);
      toggle?.classList.toggle("text-ink", on);

      navLinks.forEach((l) => {
        l.classList.toggle("text-white/85", !on);
        l.classList.toggle("hover:text-white", !on);
        l.classList.toggle("hover:bg-white/10", !on);
        l.classList.toggle("text-muted", on);
        l.classList.toggle("hover:text-ink", on);
        l.classList.toggle("hover:bg-milk", on);
        if (l.dataset.active === "true") {
          l.classList.toggle("text-white", !on);
          l.classList.toggle("text-ink", on);
        }
      });
    };

    const onScroll = () => setSolid(window.scrollY > 40);
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();
  }

  // Mobile menu toggle
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const menuIcon = document.getElementById("menu-icon");
  const closeIcon = document.getElementById("close-icon");
  btn?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden") === false;
    btn.setAttribute("aria-expanded", String(open));
    menuIcon?.classList.toggle("hidden", open);
    closeIcon?.classList.toggle("hidden", !open);
  });
</script>
