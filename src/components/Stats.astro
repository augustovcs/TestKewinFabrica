---
// Stats Component - Premium redesign
const stats = [
  { 
    label: "Anos de Mercado", 
    value: "25", 
    suffix: "+",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>`
  },
  { 
    label: "Litros Processados/Dia", 
    value: "50", 
    suffix: "k",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>`
  },
  { 
    label: "Produtos no Portfólio", 
    value: "40", 
    suffix: "+",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path></svg>`
  },
  { 
    label: "Famílias Atendidas", 
    value: "100", 
    suffix: "k+",
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>`
  }
];
---

<section id="numeros" class="py-24 relative overflow-hidden">
  <!-- Background with gradient -->
  <div class="absolute inset-0 bg-gradient-to-br from-surface-dark via-brand-navy to-surface-darker"></div>
  
  <!-- Decorative elements -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute -top-[20%] -right-[10%] w-[50vw] h-[50vw] max-w-[600px] max-h-[600px] rounded-full border-[40px] border-white/[0.03]"></div>
    <div class="absolute -bottom-[15%] -left-[10%] w-[40vw] h-[40vw] max-w-[500px] max-h-[500px] rounded-full border-[30px] border-brand-orange/[0.05]"></div>
  </div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    
    <!-- Section Header -->
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 py-2 px-5 rounded-full bg-white/5 text-brand-orange text-sm font-semibold mb-6 border border-white/10">
        <span class="w-1.5 h-1.5 rounded-full bg-brand-orange"></span>
        EM NÚMEROS
      </div>
      <h2 class="text-4xl md:text-5xl font-extrabold text-white leading-tight">
        Nossa grandeza<br />vem do <span class="text-brand-orange">campo</span>
      </h2>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8">
      {stats.map((stat, idx) => (
        <div class="group relative bg-white/5 backdrop-blur-sm border border-white/10 rounded-3xl p-8 text-center hover:bg-white/10 transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl hover:shadow-brand-blue/10">
          <!-- Icon -->
          <div class="w-14 h-14 mx-auto rounded-2xl bg-brand-orange/10 flex items-center justify-center text-brand-orange mb-6 group-hover:scale-110 group-hover:bg-brand-orange/20 transition-all duration-300">
            <Fragment set:html={stat.icon} />
          </div>
          <!-- Value -->
          <div class="text-4xl md:text-5xl font-extrabold text-white mb-3 flex justify-center items-baseline">
            {stat.value}
            <span class="text-2xl md:text-3xl ml-1 text-brand-orange">{stat.suffix}</span>
          </div>
          <!-- Label -->
          <div class="text-white/50 font-medium text-sm uppercase tracking-wider leading-tight">{stat.label}</div>
        </div>
      ))}
    </div>

  </div>
</section>
