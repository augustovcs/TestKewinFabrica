---
const year = new Date().getFullYear();
---

<!-- CTA band -->
<section class="bg-white pt-8 pb-20">
  <div class="max-w-6xl mx-auto px-5 sm:px-6 lg:px-8">
    <div class="bg-brand-blue rounded-[2rem] px-8 py-12 md:px-14 md:py-14 flex flex-col md:flex-row items-center justify-between gap-8 text-center md:text-left">
      <div>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-white leading-tight mb-2">
          Vamos levar o melhor do campo até você?
        </h2>
        <p class="text-blue-100 text-lg">Fale com a gente sobre produtos, parcerias e distribuição.</p>
      </div>
      <a
        href="mailto:contato@conleite.com.br"
        class="flex-shrink-0 bg-brand-orange text-white px-8 py-4 rounded-full font-semibold hover:bg-brand-orange-dark transition-colors"
      >Fale conosco</a>
    </div>
  </div>
</section>

<footer id="contato" class="bg-night text-white">
  <div class="max-w-6xl mx-auto px-5 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-2 md:grid-cols-12 gap-10 mb-14">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-5">
        <a href="/" class="flex items-center gap-2.5 mb-5">
          <span class="w-9 h-9 rounded-xl bg-white text-brand-blue flex items-center justify-center font-display font-bold text-lg">C</span>
          <span class="font-display font-bold text-xl">Conleite</span>
        </a>
        <p class="text-white/60 text-sm leading-relaxed max-w-xs mb-6">
          Laticínios feitos com cuidado em Vitória da Conquista, BA. Do campo
          para a sua mesa, desde 1999.
        </p>
        <div class="flex gap-2.5">
          {[
            { label: "Instagram", path: "M12 2.16c3.2 0 3.58.01 4.85.07 3.25.15 4.77 1.69 4.92 4.92.06 1.27.07 1.64.07 4.85s-.01 3.58-.07 4.85c-.15 3.23-1.66 4.77-4.92 4.92-1.27.06-1.64.07-4.85.07s-3.58-.01-4.85-.07c-3.26-.15-4.77-1.7-4.92-4.92C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85c.15-3.23 1.66-4.77 4.92-4.92C8.42 2.17 8.8 2.16 12 2.16Zm0 3.68a6.16 6.16 0 1 0 0 12.32 6.16 6.16 0 0 0 0-12.32ZM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8Zm6.41-11.85a1.44 1.44 0 1 0 0 2.88 1.44 1.44 0 0 0 0-2.88Z" },
            { label: "Facebook", path: "M24 12.07C24 5.44 18.63.07 12 .07S0 5.44 0 12.07c0 5.99 4.39 10.95 10.13 11.85v-8.38H7.08v-3.47h3.05V9.43c0-3.01 1.79-4.67 4.53-4.67 1.31 0 2.69.24 2.69.24v2.95h-1.51c-1.49 0-1.96.93-1.96 1.87v2.25h3.33l-.53 3.47h-2.8v8.38C19.61 23.02 24 18.06 24 12.07Z" },
            { label: "WhatsApp", path: "M17.47 14.38c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.96-.94 1.16-.17.2-.35.22-.64.08-.3-.15-1.26-.47-2.39-1.48-.88-.79-1.48-1.76-1.65-2.06-.17-.3-.02-.46.13-.6.13-.14.3-.35.45-.52.15-.18.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.61-.92-2.21-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.48s1.07 2.88 1.21 3.07c.15.2 2.1 3.2 5.08 4.49.71.3 1.26.49 1.69.62.71.23 1.36.2 1.87.12.57-.08 1.76-.72 2-1.41.25-.7.25-1.29.18-1.41-.08-.13-.27-.2-.57-.35M12.05 21.79h-.01a9.87 9.87 0 0 1-5.03-1.38l-.36-.21-3.74.98 1-3.65-.24-.37a9.86 9.86 0 0 1-1.51-5.26c0-5.45 4.44-9.88 9.89-9.88 2.64 0 5.12 1.03 6.98 2.9a9.83 9.83 0 0 1 2.9 6.99c0 5.45-4.44 9.88-9.88 9.88M20.46 3.49A11.82 11.82 0 0 0 12.05 0C5.5 0 .16 5.34.16 11.89c0 2.1.55 4.14 1.59 5.95L.06 24l6.3-1.65a11.88 11.88 0 0 0 5.69 1.45h.01c6.55 0 11.89-5.34 11.89-11.89 0-3.18-1.24-6.16-3.49-8.42" },
          ].map((s) => (
            <a href="#" aria-label={s.label} class="w-9 h-9 rounded-full bg-white/8 flex items-center justify-center text-white/70 hover:bg-brand-blue hover:text-white transition-colors">
              <svg class="w-4.5 h-4.5" fill="currentColor" viewBox="0 0 24 24" style="width:1.1rem;height:1.1rem"><path d={s.path} /></svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Nav -->
      <div class="md:col-span-3">
        <h3 class="text-sm font-semibold text-white/90 mb-5">Navegação</h3>
        <ul class="space-y-3 text-sm">
          <li><a href="/" class="text-white/60 hover:text-white transition-colors">Início</a></li>
          <li><a href="/sobre" class="text-white/60 hover:text-white transition-colors">A Empresa</a></li>
          <li><a href="/catalogo" class="text-white/60 hover:text-white transition-colors">Catálogo</a></li>
          <li><a href="#contato" class="text-white/60 hover:text-white transition-colors">Contato</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div class="md:col-span-4">
        <h3 class="text-sm font-semibold text-white/90 mb-5">Fale conosco</h3>
        <ul class="space-y-4 text-sm text-white/60">
          <li>Vitória da Conquista — BA, Brasil</li>
          <li><a href="mailto:contato@conleite.com.br" class="hover:text-white transition-colors">contato@conleite.com.br</a></li>
          <li><a href="tel:08000000000" class="hover:text-white transition-colors">0800 000 0000</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-white/10 pt-7 flex flex-col sm:flex-row justify-between items-center gap-3 text-sm text-white/45">
      <p>© {year} Laticínios Conleite. Todos os direitos reservados.</p>
      <div class="flex gap-6">
        <a href="#" class="hover:text-white/80 transition-colors">Privacidade</a>
        <a href="#" class="hover:text-white/80 transition-colors">Termos</a>
      </div>
    </div>
  </div>
</footer>
