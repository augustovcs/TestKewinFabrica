---
const currentYear = new Date().getFullYear();
---

<footer class="bg-surface-dark text-white pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-12">
      <!-- Logo and About -->
      <div class="col-span-1 md:col-span-1">
        <div class="flex items-center gap-2 mb-6">
          <div class="w-10 h-10 rounded-full bg-white flex items-center justify-center text-brand-dark font-bold text-xl">
            C
          </div>
          <span class="font-bold text-2xl tracking-tight">Conleite</span>
        </div>
        <p class="text-gray-300 text-sm mb-6">
          Alimentando a vida com qualidade, confiança e o verdadeiro sabor do campo. Da nossa família para a sua mesa.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h4 class="text-lg font-semibold mb-6">A Conleite</h4>
        <ul class="space-y-3">
          <li><a href="#sobre" class="text-gray-300 hover:text-white transition-colors">Sobre Nós</a></li>
          <li><a href="#fabrica" class="text-gray-300 hover:text-white transition-colors">Nossa Fábrica</a></li>
          <li><a href="#certificacoes" class="text-gray-300 hover:text-white transition-colors">Certificações</a></li>
          <li><a href="#" class="text-gray-300 hover:text-white transition-colors">Trabalhe Conosco</a></li>
        </ul>
      </div>

      <!-- Marcas -->
      <div>
        <h4 class="text-lg font-semibold mb-6">Nossas Marcas</h4>
        <ul class="space-y-3">
          <li><a href="#produtos" class="text-gray-300 hover:text-white transition-colors">Conleite</a></li>
          <li><a href="#produtos" class="text-gray-300 hover:text-white transition-colors">Laticínios Conquista</a></li>
          <li><a href="#" class="text-gray-300 hover:text-white transition-colors">Lançamentos</a></li>
        </ul>
      </div>

      <!-- Contato -->
      <div>
        <h4 class="text-lg font-semibold mb-6">Fale Conosco</h4>
        <ul class="space-y-3">
          <li class="text-gray-300 flex items-start gap-2">
            <svg class="w-5 h-5 text-brand-orange mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
            Vitória da Conquista, BA
          </li>
          <li class="text-gray-300 flex items-center gap-2">
            <svg class="w-5 h-5 text-brand-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            contato@conleite.com.br
          </li>
          <li class="text-gray-300 flex items-center gap-2">
            <svg class="w-5 h-5 text-brand-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
            0800 000 0000
          </li>
        </ul>
      </div>
    </div>

    <!-- Divider -->
    <div class="border-t border-gray-600 pt-8 mt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-gray-400 text-sm">
        &copy; {currentYear} Laticínios Conleite. Todos os direitos reservados.
      </p>
      <div class="flex gap-4">
        <a href="#" class="text-gray-400 hover:text-white transition-colors">Política de Privacidade</a>
        <a href="#" class="text-gray-400 hover:text-white transition-colors">Termos de Uso</a>
      </div>
    </div>
  </div>
</footer>
