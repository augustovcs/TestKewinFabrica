---
import { site, whatsappLink } from "../data/site";
import { products } from "../data/products";
const year = new Date().getFullYear();
const wa = whatsappLink();

const socials = [
  { label: "Instagram", href: site.social.instagram, path: "M12 2.16c3.2 0 3.58.01 4.85.07 3.25.15 4.77 1.69 4.92 4.92.06 1.27.07 1.64.07 4.85s-.01 3.58-.07 4.85c-.15 3.23-1.66 4.77-4.92 4.92-1.27.06-1.64.07-4.85.07s-3.58-.01-4.85-.07c-3.26-.15-4.77-1.7-4.92-4.92C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85c.15-3.23 1.66-4.77 4.92-4.92C8.42 2.17 8.8 2.16 12 2.16Zm0 3.68a6.16 6.16 0 1 0 0 12.32 6.16 6.16 0 0 0 0-12.32ZM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8Zm6.41-11.85a1.44 1.44 0 1 0 0 2.88 1.44 1.44 0 0 0 0-2.88Z" },
  { label: "Facebook", href: site.social.facebook, path: "M24 12.07C24 5.44 18.63.07 12 .07S0 5.44 0 12.07c0 5.99 4.39 10.95 10.13 11.85v-8.38H7.08v-3.47h3.05V9.43c0-3.01 1.79-4.67 4.53-4.67 1.31 0 2.69.24 2.69.24v2.95h-1.51c-1.49 0-1.96.93-1.96 1.87v2.25h3.33l-.53 3.47h-2.8v8.38C19.61 23.02 24 18.06 24 12.07Z" },
  { label: "WhatsApp", href: wa, path: "M17.47 14.38c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.96-.94 1.16-.17.2-.35.22-.64.08-.3-.15-1.26-.47-2.39-1.48-.88-.79-1.48-1.76-1.65-2.06-.17-.3-.02-.46.13-.6.13-.14.3-.35.45-.52.15-.18.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.61-.92-2.21-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.48s1.07 2.88 1.21 3.07c.15.2 2.1 3.2 5.08 4.49.71.3 1.26.49 1.69.62.71.23 1.36.2 1.87.12.57-.08 1.76-.72 2-1.41.25-.7.25-1.29.18-1.41-.08-.13-.27-.2-.57-.35M12.05 21.79h-.01a9.87 9.87 0 0 1-5.03-1.38l-.36-.21-3.74.98 1-3.65-.24-.37a9.86 9.86 0 0 1-1.51-5.26c0-5.45 4.44-9.88 9.89-9.88 2.64 0 5.12 1.03 6.98 2.9a9.83 9.83 0 0 1 2.9 6.99c0 5.45-4.44 9.88-9.88 9.88" },
];

// Colunas de navegação (conteúdo real Conquista)
const categorias = ["Leites", "Bebida Láctea", "Iogurtes", "Derivados"];
const marcas = [site.brandShort, site.subBrand];
const tiposA = products.slice(0, 4);
const tiposB = products.slice(4);
const navegacao = [
  { label: "Início", href: "/" },
  { label: "A Empresa", href: "/sobre" },
  { label: "Catálogo", href: "/catalogo" },
  { label: "Fale conosco", href: "/#contato" },
];
const institucional = [
  { label: "A Empresa", href: "/sobre" },
  { label: "Fale conosco", href: "/#contato" },
];

---

<!-- Onda animada (igual à do hero, maior, MESMA cor lisa do footer) — o topo do footer "ondula" -->
<div class="relative -mb-px h-[64px] sm:h-[104px] overflow-hidden leading-[0]" aria-hidden="true">
  <svg class="wave-hero-svg absolute inset-0 w-[200%] h-full" viewBox="0 0 2880 130" preserveAspectRatio="none">
    <path fill="#163225" d="M0,66 q180,54 360,0 t360,0 t360,0 t360,0 t360,0 t360,0 t360,0 t360,0 L2880,130 L0,130 Z" />
  </svg>
</div>

<footer id="contato-footer" class="relative bg-brand-green-ink text-white overflow-hidden">
  <div class="absolute -top-10 right-1/4 w-96 h-96 rounded-full bg-brand-lime/8 blur-[120px] blob pointer-events-none" aria-hidden></div>
  <div class="relative z-10 max-w-6xl mx-auto px-5 sm:px-6 lg:px-8 pt-20 pb-24 lg:pt-24 lg:pb-28">
    <!-- Colunas de navegação (6) -->
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-8 lg:gap-6 mb-14 reveal">
      <div>
        <h3 class="text-sm font-bold text-white/90 mb-5">Categorias</h3>
        <ul class="space-y-3 text-sm">
          {categorias.map((c) => (
            <li><a href="/catalogo" class="text-white/60 hover:text-brand-lime transition-colors">{c}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-bold text-white/90 mb-5">Marcas</h3>
        <ul class="space-y-3 text-sm">
          {marcas.map((m) => (
            <li><a href="/catalogo" class="text-white/60 hover:text-brand-lime transition-colors">{m}</a></li>
          ))}
        </ul>
      </div>

      <!-- Tipos de Produto — 2 sub-colunas -->
      <div>
        <h3 class="text-sm font-bold text-white/90 mb-5">Tipos de Produto</h3>
        <ul class="space-y-3 text-sm">
          {tiposA.map((p) => (
            <li><a href={`/catalogo#${p.id}`} class="text-white/60 hover:text-brand-lime transition-colors">{p.name}</a></li>
          ))}
        </ul>
      </div>
      <div class="lg:pt-9">
        <ul class="space-y-3 text-sm">
          {tiposB.map((p) => (
            <li><a href={`/catalogo#${p.id}`} class="text-white/60 hover:text-brand-lime transition-colors">{p.name}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-bold text-white/90 mb-5">Navegação</h3>
        <ul class="space-y-3 text-sm">
          {navegacao.map((n) => (
            <li><a href={n.href} class="text-white/60 hover:text-brand-lime transition-colors">{n.label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-bold text-white/90 mb-5">Institucional</h3>
        <ul class="space-y-3 text-sm">
          {institucional.map((n) => (
            <li><a href={n.href} class="text-white/60 hover:text-brand-lime transition-colors">{n.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Sociais bare bottom-left + copyright minimal (tudo à esquerda) -->
    <div class="border-t border-white/10 pt-7 flex flex-col gap-5 items-start">
      <div class="flex items-center gap-5">
        {socials.map((s) => (
          <a href={s.href} target="_blank" rel="noopener" aria-label={s.label} class="text-white/55 hover:text-brand-lime transition-colors">
            <svg fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5"><path d={s.path} /></svg>
          </a>
        ))}
      </div>
      <p class="text-sm text-white/45">© {year} {site.brand}. Todos os direitos reservados.</p>
    </div>
  </div>
</footer>
