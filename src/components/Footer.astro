---
import { site, fullAddress, whatsappLink } from "../data/site";
const year = new Date().getFullYear();
const wa = whatsappLink();

const socials = [
  { label: "Instagram", href: site.social.instagram, path: "M12 2.16c3.2 0 3.58.01 4.85.07 3.25.15 4.77 1.69 4.92 4.92.06 1.27.07 1.64.07 4.85s-.01 3.58-.07 4.85c-.15 3.23-1.66 4.77-4.92 4.92-1.27.06-1.64.07-4.85.07s-3.58-.01-4.85-.07c-3.26-.15-4.77-1.7-4.92-4.92C2.17 15.58 2.16 15.2 2.16 12s.01-3.58.07-4.85c.15-3.23 1.66-4.77 4.92-4.92C8.42 2.17 8.8 2.16 12 2.16Zm0 3.68a6.16 6.16 0 1 0 0 12.32 6.16 6.16 0 0 0 0-12.32ZM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8Zm6.41-11.85a1.44 1.44 0 1 0 0 2.88 1.44 1.44 0 0 0 0-2.88Z" },
  { label: "Facebook", href: site.social.facebook, path: "M24 12.07C24 5.44 18.63.07 12 .07S0 5.44 0 12.07c0 5.99 4.39 10.95 10.13 11.85v-8.38H7.08v-3.47h3.05V9.43c0-3.01 1.79-4.67 4.53-4.67 1.31 0 2.69.24 2.69.24v2.95h-1.51c-1.49 0-1.96.93-1.96 1.87v2.25h3.33l-.53 3.47h-2.8v8.38C19.61 23.02 24 18.06 24 12.07Z" },
  { label: "WhatsApp", href: wa, path: "M17.47 14.38c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.96-.94 1.16-.17.2-.35.22-.64.08-.3-.15-1.26-.47-2.39-1.48-.88-.79-1.48-1.76-1.65-2.06-.17-.3-.02-.46.13-.6.13-.14.3-.35.45-.52.15-.18.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.61-.92-2.21-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.48s1.07 2.88 1.21 3.07c.15.2 2.1 3.2 5.08 4.49.71.3 1.26.49 1.69.62.71.23 1.36.2 1.87.12.57-.08 1.76-.72 2-1.41.25-.7.25-1.29.18-1.41-.08-.13-.27-.2-.57-.35M12.05 21.79h-.01a9.87 9.87 0 0 1-5.03-1.38l-.36-.21-3.74.98 1-3.65-.24-.37a9.86 9.86 0 0 1-1.51-5.26c0-5.45 4.44-9.88 9.89-9.88 2.64 0 5.12 1.03 6.98 2.9a9.83 9.83 0 0 1 2.9 6.99c0 5.45-4.44 9.88-9.88 9.88" },
];
---

<footer id="contato-footer" class="relative bg-brand-green-ink grain text-white">
  <div class="relative z-10 max-w-6xl mx-auto px-5 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-2 md:grid-cols-12 gap-10 mb-14">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-5">
        <a href="/" class="inline-flex flex-col mb-5">
          <span class="font-display font-extrabold text-2xl tracking-tight leading-none">
            Laticínios <span class="text-brand-lime">Conquista</span>
          </span>
          <span class="text-white/50 text-xs mt-1.5 uppercase tracking-[0.18em]">{site.tagline}</span>
        </a>
        <p class="text-white/55 text-sm leading-relaxed max-w-xs mb-6">
          Leite, bebida láctea, iogurte e manteiga feitos em Vitória da Conquista, BA.
          Qualidade que se põe à mesa da família.
        </p>
        <div class="flex gap-2.5">
          {socials.map((s) => (
            <a href={s.href} target="_blank" rel="noopener" aria-label={s.label} class="w-9 h-9 rounded-[8px] bg-white/8 flex items-center justify-center text-white/70 hover:bg-brand-pink hover:text-white transition-colors">
              <svg fill="currentColor" viewBox="0 0 24 24" class="w-[1.05rem] h-[1.05rem]"><path d={s.path} /></svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Nav -->
      <div class="md:col-span-3">
        <h3 class="text-sm font-bold text-white/90 mb-5">Navegação</h3>
        <ul class="space-y-3 text-sm">
          <li><a href="/" class="text-white/60 hover:text-brand-lime transition-colors">Início</a></li>
          <li><a href="/sobre" class="text-white/60 hover:text-brand-lime transition-colors">A Empresa</a></li>
          <li><a href="/catalogo" class="text-white/60 hover:text-brand-lime transition-colors">Catálogo</a></li>
          <li><a href="/#contato" class="text-white/60 hover:text-brand-lime transition-colors">Fale conosco</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div class="md:col-span-4">
        <h3 class="text-sm font-bold text-white/90 mb-5">Contato</h3>
        <ul class="space-y-4 text-sm text-white/60">
          <li class="leading-relaxed">{fullAddress}<br />CEP {site.address.zip}</li>
          {site.phones.map((p) => (
            <li><a href={`tel:${p.tel}`} class="hover:text-brand-lime transition-colors">{p.label}</a></li>
          ))}
          <li><a href={`mailto:${site.email}`} class="hover:text-brand-lime transition-colors">{site.email}</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-white/10 pt-7 flex flex-col sm:flex-row justify-between items-center gap-3 text-sm text-white/45">
      <p>© {year} {site.brand}. Todos os direitos reservados.</p>
      <p class="text-white/35">Indústria Brasileira · Inspeção Federal</p>
    </div>
  </div>
</footer>
